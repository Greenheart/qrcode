{
  "name": "@slidoapp/qrcode",
  "description": "Generate Quick Response (QR) codes using JavaScript in a browser, server side code, or using a command line tool.",
  "version": "2.1.0",
  "author": "Ryan Day <soldair@gmail.com>",
  "contributors": [
    "Vincenzo Greco <greco.vincenzo@gmail.com>",
    "Linus Unnebäck <linus@folkdatorn.se>",
    "Jozef Izso <izso@cisco.com>"
  ],
  "keywords": [
    "qr",
    "code",
    "canvas",
    "qrcode"
  ],
  "main": "./lib/index.js",
  "browser": {
    "./lib/index.js": "./lib/browser.js",
    "fs": false
  },
  "types": "./types/index.d.ts",
  "files": [
    "bin",
    "build",
    "lib",
    "helper",
    "types"
  ],
  "homepage": "https://github.com/slidoapp/node-qrcode",
  "license": "MIT",
  "scripts": {
    "lint": "standard --fix",
    "pretest": "pnpm lint",
    "test": "vitest",
    "build": "rollup -c",
    "prepublish": "pnpm build",
    "browser": "node examples/clientsideserver.js"
  },
  "bin": {
    "qrcode": "./bin/qrcode"
  },
  "dependencies": {
    "@types/pngjs": "^6.0.5",
    "dijkstrajs": "^1.0.3",
    "pngjs": "^7.0.0",
    "yargs": "^18.0.0"
  },
  "devDependencies": {
    "@babel/core": "^7.29.0",
    "@babel/preset-env": "^7.29.0",
    "@rollup/plugin-babel": "^7.0.0",
    "@rollup/plugin-commonjs": "^29.0.0",
    "@rollup/plugin-node-resolve": "^16.0.3",
    "@rollup/plugin-terser": "^1.0.0",
    "@types/node": "^25.3.3",
    "@types/sinon": "^21.0.0",
    "browserify": "^17.0.1",
    "canvas": "^3.0.0-rc2",
    "canvasutil": "0.0.4",
    "colors": "^1.4.0",
    "express": "^4.21.1",
    "htmlparser2": "^10.1.0",
    "oxfmt": "^0.36.0",
    "oxlint": "^1.51.0",
    "rollup": "^4.59.0",
    "sinon": "^21.0.2",
    "standard": "^17.1.2",
    "tap": "^21.6.2",
    "typescript": "^5.9.3",
    "vitest": "^4.0.18"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/slidoapp/node-qrcode.git"
  },
  "imports": {
    "#renderer/*": "./lib/renderer/*",
    "#lib/*": "./lib/*",
    "#core/*": "./lib/core/*",
    "#test/*": "./test/*",
    "#helper/*": "./helper/*"
  },
  "engines": {
    "node": ">=18"
  },
  "standard": {
    "ignore": [
      "build/",
      "examples/vendors/",
      "lib/core/regex.js"
    ]
  },
  "type": "module"
}
