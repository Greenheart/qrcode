{
  "name": "@slidoapp/qrcode",
  "version": "2.1.0",
  "description": "Generate Quick Response (QR) codes using JavaScript in a browser, server side code, or using a command line tool.",
  "keywords": [
    "canvas",
    "code",
    "qr",
    "qrcode"
  ],
  "homepage": "https://github.com/slidoapp/node-qrcode",
  "license": "MIT",
  "author": "Ryan Day <soldair@gmail.com>",
  "contributors": [
    "Vincenzo Greco <greco.vincenzo@gmail.com>",
    "Linus Unnebäck <linus@folkdatorn.se>",
    "Jozef Izso <izso@cisco.com>"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/slidoapp/node-qrcode.git"
  },
  "bin": {
    "qrcode": "./bin/qrcode.ts"
  },
  "files": [
    "bin",
    "build",
    "lib",
    "helper",
    "types"
  ],
  "type": "module",
  "main": "./lib/index.ts",
  "browser": {
    "./lib/index.js": "./lib/browser.ts",
    "fs": false
  },
  "types": "./types/index.d.ts",
  "imports": {
    "#renderer/*": "./lib/renderer/*",
    "#lib/*": "./lib/*",
    "#core/*": "./lib/core/*",
    "#test/*": "./test/*",
    "#helper/*": "./helper/*"
  },
  "scripts": {
    "lint": "oxlint",
    "format": "oxfmt --write",
    "pretest": "pnpm lint",
    "test": "vitest",
    "test:coverage": "vitest --run --coverage",
    "build": "rollup -c",
    "prepublish": "pnpm build",
    "browser": "node examples/clientsideserver.js"
  },
  "dependencies": {
    "commander": "15.0.0-0",
    "dijkstra-find-path": "^2.0.0",
    "pngjs": "^7.0.0"
  },
  "devDependencies": {
    "@babel/core": "^7.29.0",
    "@babel/preset-env": "^7.29.0",
    "@e18e/eslint-plugin": "^0.2.0",
    "@rollup/plugin-babel": "^7.0.0",
    "@rollup/plugin-commonjs": "^29.0.2",
    "@rollup/plugin-node-resolve": "^16.0.3",
    "@rollup/plugin-terser": "^1.0.0",
    "@types/node": "^25.5.0",
    "@types/pngjs": "^6.0.5",
    "@types/sinon": "^21.0.0",
    "@vitest/coverage-v8": "^4.1.0",
    "canvas": "^3.2.1",
    "canvasutil": "0.0.4",
    "express": "^4.22.1",
    "htmlparser2": "^10.1.0",
    "oxfmt": "^0.40.0",
    "oxlint": "^1.55.0",
    "rollup": "^4.59.0",
    "sinon": "^21.0.2",
    "typescript": "^5.9.3",
    "vitest": "^4.1.0"
  },
  "engines": {
    "node": ">=24"
  }
}
